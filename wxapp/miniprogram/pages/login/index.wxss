.login-page {
  min-height: 100vh;
  padding-bottom: 48rpx;
  background: #f7f8fb;
}

.nav-back {
  position: absolute;
  left: 32rpx;
  bottom: 28rpx;
  width: 44rpx;
  height: 44rpx;
  color: #101828;
}

.nav-back::before {
  content: "";
  position: absolute;
  left: 15rpx;
  top: 10rpx;
  width: 20rpx;
  height: 20rpx;
  border-left: 4rpx solid currentColor;
  border-bottom: 4rpx solid currentColor;
  transform: rotate(45deg);
}

.login-content {
  padding: 32rpx 32rpx 0;
}

.login-hero {
  padding: 16rpx 4rpx 28rpx;
}

.hero-icon {
  width: 72rpx;
  height: 72rpx;
  margin-bottom: 24rpx;
  border-radius: 18rpx;
  background: #eef4ff;
  color: #2f7bff;
  position: relative;
}

.hero-icon-book {
  position: absolute;
  left: 19rpx;
  top: 17rpx;
  width: 34rpx;
  height: 38rpx;
  border: 4rpx solid currentColor;
  border-radius: 5rpx 10rpx 10rpx 5rpx;
}

.hero-icon-book::before {
  content: "";
  position: absolute;
  left: 9rpx;
  top: 7rpx;
  height: 20rpx;
  border-left: 3rpx solid currentColor;
}

.title {
  color: #101828;
  font-size: 44rpx;
  font-weight: 800;
  line-height: 1.15;
}

.subtitle {
  max-width: 620rpx;
  margin-top: 16rpx;
  color: #667085;
  font-size: 26rpx;
  line-height: 1.5;
}

.form-panel {
  padding: 32rpx 28rpx 34rpx;
  border-radius: 18rpx;
}

.field + .field {
  margin-top: 28rpx;
}

.label-row {
  min-height: 34rpx;
  margin-bottom: 14rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.label {
  flex: 0 0 auto;
  color: #344054;
  font-size: 27rpx;
  font-weight: 800;
  line-height: 1;
}

.field-hint {
  min-width: 0;
  color: #98a2b3;
  font-size: 23rpx;
  line-height: 1;
}

.input {
  box-sizing: border-box;
  width: 100%;
  height: 92rpx;
  padding: 0 24rpx;
  border: 1rpx solid #d0d5dd;
  border-radius: 14rpx;
  background: #ffffff;
  color: #101828;
  font-size: 30rpx;
}

.input:focus {
  border-color: #2f7bff;
}

.school-field {
  position: relative;
  z-index: 2;
}

.school-select {
  position: relative;
}

.school-input {
  padding-right: 72rpx;
}

.school-arrow {
  position: absolute;
  right: 26rpx;
  top: 34rpx;
  width: 18rpx;
  height: 18rpx;
  border-right: 3rpx solid #667085;
  border-bottom: 3rpx solid #667085;
  transform: rotate(45deg);
  transition: transform 0.18s ease;
}

.school-arrow-open {
  top: 40rpx;
  transform: rotate(225deg);
}

.school-options {
  margin-top: 12rpx;
  border: 1rpx solid #d0d5dd;
  border-radius: 14rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 30rpx rgba(16, 24, 40, 0.08);
  overflow: hidden;
}

.school-option {
  min-height: 84rpx;
  padding: 0 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  border-bottom: 1rpx solid #eef0f4;
}

.school-option:last-child {
  border-bottom: 0;
}

.school-option-active {
  background: #eef4ff;
  color: #2f7bff;
}

.school-name {
  min-width: 0;
  color: inherit;
  font-size: 29rpx;
  font-weight: 700;
  line-height: 1.3;
}

.school-check {
  flex: 0 0 auto;
  width: 22rpx;
  height: 12rpx;
  border-left: 4rpx solid currentColor;
  border-bottom: 4rpx solid currentColor;
  transform: rotate(-45deg);
}

.school-empty {
  height: 84rpx;
  padding: 0 24rpx;
  color: #98a2b3;
  font-size: 26rpx;
  line-height: 84rpx;
}

.login-button {
  width: 100%;
  margin-top: 36rpx;
  border-radius: 14rpx;
  font-weight: 700;
}

.security-card {
  margin-top: 22rpx;
  padding: 24rpx 26rpx;
  display: flex;
  gap: 18rpx;
  border: 1rpx solid #dbeafe;
  border-radius: 16rpx;
  background: #eff6ff;
}

.security-icon {
  flex: 0 0 34rpx;
  width: 34rpx;
  height: 38rpx;
  margin-top: 2rpx;
  border: 3rpx solid #2f7bff;
  border-radius: 7rpx;
  position: relative;
}

.security-icon::before {
  content: "";
  position: absolute;
  left: 6rpx;
  top: -16rpx;
  width: 16rpx;
  height: 18rpx;
  border: 3rpx solid #2f7bff;
  border-bottom: 0;
  border-radius: 12rpx 12rpx 0 0;
}

.security-title {
  margin-bottom: 8rpx;
  color: #1d4ed8;
  font-size: 26rpx;
  font-weight: 800;
  line-height: 1;
}

.note {
  color: #475467;
  font-size: 24rpx;
  line-height: 1.5;
}
