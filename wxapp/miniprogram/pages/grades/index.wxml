<view class="mini-page">
  <view class="custom-nav" style="{{navStyle}}">
    <view class="custom-nav-title">成绩</view>
  </view>

  <view class="content">
    <view class="score-summary">
      <view class="score-summary-title">学业总览</view>
      <view class="metric-row">
        <view wx:for="{{summary}}" wx:key="label" class="metric">
          <view class="metric-value">{{item.value}}</view>
          <view class="metric-label">{{item.label}}</view>
        </view>
      </view>
      <view class="cap-icon"></view>
    </view>

    <view class="exam-section">
      <view class="filter">考试安排 <view class="exam-count">{{exams.length}}</view></view>
      <view wx:if="{{exams.length === 0}}" class="soft-card exam-empty">{{examEmptyText}}</view>
      <block wx:else>
        <view
          class="soft-card exam-stack {{examListExpanded ? 'exam-stack-open' : ''}}"
          bindtap="toggleExamList"
        >
          <view class="exam-stack-main">
            <view class="exam-stack-title">{{examSummary.title}}</view>
            <view class="exam-stack-subtitle">{{examSummary.subtitle}}</view>
          </view>
          <view class="exam-stack-count">{{examSummary.total}}</view>
          <view class="exam-stack-toggle"></view>
        </view>

        <view wx:if="{{examListExpanded}}" class="exam-list">
          <view
            wx:for="{{exams}}"
            wx:key="id"
            class="soft-card exam-row exam-row-{{item.examStatusKey}} {{item.expanded ? 'exam-row-expanded' : 'exam-row-collapsed'}}"
            bindtap="toggleExam"
            data-index="{{index}}"
          >
            <view class="exam-head">
              <view class="exam-date">
                <text>{{item.dateText}}</text>
                <text wx:if="{{item.examStatusKey === 'upcoming'}}">{{item.time}}</text>
                <text wx:elif="{{item.examStatusKey === 'completed'}}">{{item.batchName || '已考完'}}</text>
                <text wx:else>待安排</text>
              </view>
              <view class="exam-main">
                <view class="exam-title">{{item.name}}</view>
                <view class="exam-meta">
                  <text wx:if="{{item.batchName}}">{{item.batchName}}</text>
                  <text wx:if="{{item.examStatusKey === 'upcoming'}}">{{item.location}}</text>
                  <text wx:elif="{{item.examStatusKey === 'completed'}}">考试已结束</text>
                  <text wx:else>时间地点待安排</text>
                </view>
              </view>
              <view class="exam-status exam-status-{{item.examStatusKey}}">{{item.examStatusText}}</view>
              <view class="exam-toggle {{item.expanded ? 'exam-toggle-open' : ''}}"></view>
            </view>

            <view wx:if="{{item.expanded}}" class="exam-detail">
              <view class="exam-detail-grid">
                <view wx:if="{{item.batchName}}" class="exam-detail-item">
                  <text class="exam-detail-label">批次</text>
                  <text class="exam-detail-value">{{item.batchName}}</text>
                </view>
                <view class="exam-detail-item">
                  <text class="exam-detail-label">日期</text>
                  <text class="exam-detail-value">{{item.dateText}}</text>
                </view>
                <view class="exam-detail-item">
                  <text class="exam-detail-label">时间</text>
                  <text class="exam-detail-value">{{item.time}}</text>
                </view>
                <view class="exam-detail-item">
                  <text class="exam-detail-label">状态</text>
                  <text class="exam-detail-value">{{item.examStatusText}}</text>
                </view>
                <block wx:if="{{item.examStatusKey === 'upcoming'}}">
                  <view class="exam-detail-item">
                    <text class="exam-detail-label">地点</text>
                    <text class="exam-detail-value">{{item.location}}</text>
                  </view>
                  <view class="exam-detail-item">
                    <text class="exam-detail-label">座位</text>
                    <text class="exam-detail-value">{{item.seatText}}</text>
                  </view>
                </block>
              </view>
            </view>
          </view>
        </view>
      </block>
    </view>

    <view class="filter">全部学期 <view class="chevron-down"></view></view>

    <view wx:if="{{loading}}" class="soft-card grade-state">正在加载成绩...</view>
    <view wx:elif="{{errorText}}" class="soft-card grade-state grade-error">{{errorText}}</view>
    <view wx:elif="{{semesters.length === 0}}" class="soft-card grade-state">{{emptyText}}</view>

    <view
      wx:for="{{semesters}}"
      wx:key="id"
      class="soft-card semester-card {{item.expanded ? '' : 'semester-collapsed'}}"
    >
      <view class="semester-top" bindtap="toggleSemester" data-index="{{index}}">
        <view>
          <view class="semester-title">{{item.title}}</view>
          <view class="semester-stats">
            <text>学分：{{item.credit}}</text>
            <text>平均分：{{item.average}}</text>
            <text>绩点：{{item.gpa}}</text>
          </view>
        </view>
        <view class="collapse-icon"></view>
      </view>

      <view wx:if="{{item.expanded}}" class="grade-table">
        <view class="grade-row">
          <view class="grade-cell grade-head grade-name">课程名称</view>
          <view class="grade-cell grade-head grade-num">学分</view>
          <view class="grade-cell grade-head grade-num">成绩</view>
          <view class="grade-cell grade-head grade-num">绩点</view>
        </view>
        <block wx:for="{{item.grades}}" wx:key="name" wx:for-item="grade">
          <view class="grade-row">
            <view class="grade-cell grade-name">{{grade.name}}</view>
            <view class="grade-cell grade-num">{{grade.credit}}</view>
            <view class="grade-cell grade-num {{grade.scoreLow ? 'grade-score-low' : ''}}">{{grade.score}}</view>
            <view class="grade-cell grade-num">{{grade.gpa}}</view>
          </view>
        </block>
      </view>
    </view>
  </view>

  <view class="tabbar">
    <view class="tab" bindtap="goHome">
      <view class="tab-icon icon-home"></view>
      <text>首页</text>
    </view>
    <view class="tab" bindtap="goSchedule">
      <view class="tab-icon icon-calendar"></view>
      <text>课表</text>
    </view>
    <view class="tab tab-active" bindtap="goGrades">
      <view class="tab-icon icon-score"></view>
      <text>成绩</text>
    </view>
    <view class="tab" bindtap="goProfile">
      <view class="tab-icon icon-user"></view>
      <text>个人</text>
    </view>
  </view>
</view>
