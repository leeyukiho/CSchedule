.score-summary {
  height: 240rpx;
  padding: 36rpx 28rpx 28rpx;
  border: 1rpx solid #d9e8ff;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #eef6ff, #e8f2ff 55%, #dcecff);
  position: relative;
  overflow: hidden;
  margin-bottom: 34rpx;
}

.score-summary::before {
  content: "";
  position: absolute;
  right: -20rpx;
  top: -22rpx;
  width: 150rpx;
  height: 150rpx;
  border-radius: 50%;
  background: rgba(47, 123, 255, 0.1);
}

.score-summary-title {
  margin-bottom: 40rpx;
  color: #101828;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 1;
}

.metric-row {
  display: flex;
  justify-content: space-between;
}

.metric {
  flex: 1;
}

.metric-value {
  margin-bottom: 22rpx;
  color: #101828;
  font-size: 40rpx;
  font-weight: 800;
  line-height: 1;
}

.metric-label {
  color: #344054;
  font-size: 24rpx;
  line-height: 1;
}

.cap-icon {
  position: absolute;
  right: 28rpx;
  top: 28rpx;
  width: 88rpx;
  height: 48rpx;
  opacity: 0.14;
}

.cap-icon::before {
  content: "";
  position: absolute;
  left: 0;
  top: 12rpx;
  width: 78rpx;
  height: 30rpx;
  background: #2f7bff;
  transform: skewX(-25deg);
}

.cap-icon::after {
  content: "";
  position: absolute;
  left: 34rpx;
  top: 34rpx;
  width: 24rpx;
  height: 26rpx;
  border-left: 4rpx solid #2f7bff;
  border-bottom: 4rpx solid #2f7bff;
}

.filter {
  height: 50rpx;
  display: flex;
  align-items: center;
  gap: 14rpx;
  color: #4b5563;
  font-size: 26rpx;
  margin: 0 0 20rpx 4rpx;
}

.exam-section {
  margin-bottom: 32rpx;
}

.exam-count {
  min-width: 34rpx;
  height: 34rpx;
  padding: 0 10rpx;
  border-radius: 999rpx;
  background: #eef4ff;
  color: #2f7bff;
  font-size: 22rpx;
  font-weight: 800;
  line-height: 34rpx;
  text-align: center;
}

.exam-stack {
  min-height: 124rpx;
  padding: 26rpx 24rpx;
  display: flex;
  align-items: center;
  gap: 18rpx;
  position: relative;
}

.exam-stack::after {
  content: "";
  position: absolute;
  left: 26rpx;
  right: 26rpx;
  bottom: -8rpx;
  height: 12rpx;
  border-radius: 0 0 14rpx 14rpx;
  background: rgba(47, 123, 255, 0.08);
}

.exam-stack-main {
  flex: 1;
  min-width: 0;
}

.exam-stack-title {
  margin-bottom: 14rpx;
  color: #101828;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 1.2;
}

.exam-stack-subtitle {
  color: #667085;
  font-size: 23rpx;
  line-height: 1.3;
  word-break: break-all;
}

.exam-stack-count {
  flex: 0 0 auto;
  min-width: 48rpx;
  height: 48rpx;
  padding: 0 12rpx;
  border-radius: 999rpx;
  background: #eef4ff;
  color: #2f7bff;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 48rpx;
  text-align: center;
}

.exam-stack-toggle {
  flex: 0 0 auto;
  width: 18rpx;
  height: 18rpx;
  border-right: 3rpx solid #98a2b3;
  border-bottom: 3rpx solid #98a2b3;
  transform: rotate(45deg);
  transition: transform 0.2s ease;
}

.exam-stack-open .exam-stack-toggle {
  transform: rotate(225deg);
}

.exam-list {
  margin-top: 18rpx;
}

.exam-row {
  margin-bottom: 16rpx;
  overflow: hidden;
}

.exam-row-completed {
  background: #fafafa;
}

.exam-row-completed .exam-title,
.exam-row-completed .exam-date {
  color: #667085;
}

.exam-row-unscheduled {
  background: #fbfcfe;
}

.exam-head {
  min-height: 132rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.exam-date {
  flex: 0 0 132rpx;
  min-width: 0;
  color: #2f7bff;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 1.25;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.exam-main {
  flex: 1;
  min-width: 0;
}

.exam-title {
  margin-bottom: 14rpx;
  color: #101828;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 1.25;
}

.exam-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx 18rpx;
  color: #667085;
  font-size: 23rpx;
  line-height: 1.25;
}

.exam-meta text {
  max-width: 100%;
}

.exam-status {
  flex: 0 0 auto;
  min-width: 64rpx;
  font-size: 24rpx;
  font-weight: 800;
  text-align: right;
}

.exam-status-upcoming {
  color: #2f7bff;
}

.exam-status-completed {
  color: #667085;
}

.exam-status-unscheduled {
  color: #98a2b3;
}

.exam-toggle {
  flex: 0 0 auto;
  width: 18rpx;
  height: 18rpx;
  border-right: 3rpx solid #98a2b3;
  border-bottom: 3rpx solid #98a2b3;
  transform: rotate(45deg);
  transition: transform 0.2s ease;
}

.exam-toggle-open {
  transform: rotate(225deg);
}

.exam-detail {
  margin: 0 24rpx 24rpx 176rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid #eef0f4;
}

.exam-detail-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx 20rpx;
}

.exam-detail-item {
  flex: 1 1 220rpx;
  min-width: 0;
}

.exam-detail-label {
  display: block;
  margin-bottom: 8rpx;
  color: #98a2b3;
  font-size: 21rpx;
  line-height: 1;
}

.exam-detail-value {
  display: block;
  color: #344054;
  font-size: 24rpx;
  line-height: 1.3;
  word-break: break-all;
}

.exam-row-completed .exam-detail-value,
.exam-row-unscheduled .exam-detail-value {
  color: #667085;
}

.exam-empty {
  min-height: 100rpx;
  padding: 28rpx;
  color: #98a2b3;
  font-size: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.chevron-down {
  width: 16rpx;
  height: 16rpx;
  border-right: 3rpx solid currentColor;
  border-bottom: 3rpx solid currentColor;
  transform: rotate(45deg);
  margin-top: -6rpx;
}

.semester-card {
  margin-bottom: 20rpx;
  overflow: hidden;
}

.semester-top {
  min-height: 114rpx;
  padding: 28rpx 24rpx 20rpx;
  display: flex;
  align-items: start;
  justify-content: space-between;
}

.semester-top > view:first-child {
  flex: 1;
  min-width: 0;
}

.semester-title {
  margin-bottom: 16rpx;
  color: #101828;
  font-size: 26rpx;
  font-weight: 800;
  line-height: 1;
}

.semester-stats {
  display: flex;
  gap: 28rpx;
  color: #4b5563;
  font-size: 24rpx;
  line-height: 1;
  white-space: nowrap;
}

.collapse-icon {
  width: 18rpx;
  height: 18rpx;
  border-left: 3rpx solid #101828;
  border-top: 3rpx solid #101828;
  transform: rotate(45deg);
  margin: 8rpx auto 0;
}

.semester-collapsed .collapse-icon {
  border-left: 0;
  border-top: 0;
  border-right: 3rpx solid #101828;
  border-bottom: 3rpx solid #101828;
  margin-top: 0;
}

.grade-table {
  border-top: 1rpx solid #eef0f4;
}

.grade-row {
  min-height: 68rpx;
  display: flex;
  border-bottom: 1rpx solid #eef0f4;
}

.grade-cell {
  flex: 1;
  min-height: 68rpx;
  padding: 20rpx 22rpx;
  color: #111827;
  font-size: 22rpx;
  line-height: 1.1;
  display: flex;
  align-items: center;
}

.grade-name {
  flex: 1.75;
}

.grade-head {
  color: #667085;
}

.grade-num {
  justify-content: center;
}

.grade-score-low {
  color: #e11d48;
  font-weight: 800;
}

.grade-state {
  min-height: 180rpx;
  padding: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #667085;
  font-size: 28rpx;
  text-align: center;
}

.grade-error {
  color: #e11d48;
  background: #fff1f2;
}
