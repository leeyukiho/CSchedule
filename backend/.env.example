# =========================
# 生产必填：后端基础配置
# =========================

# 必填：运行环境；生产环境填写 production，本地开发可填写 development。
NODE_ENV=production

# 必填：后端监听端口；Nginx 或宝塔反向代理一般转发到这个端口。
PORT=3000

# 必填：PostgreSQL 连接地址；生产环境请改成真实数据库账号、密码、地址和库名。
DATABASE_URL=postgresql://cschedule:cschedule@127.0.0.1:5432/cschedule?schema=public&connection_limit=5&pool_timeout=10

# 必填：允许访问普通后端 API 的前端域名；多个域名用英文逗号分隔。
CORS_ORIGIN=https://servicewechat.com,https://developers.weixin.qq.com

# 必填：管理后台接口密钥；生产环境必须改成高强度随机字符串。
ADMIN_API_KEY=change-me-to-a-secure-random-string

# 必填：允许访问 Admin API 的管理后台域名；多个域名用英文逗号分隔。
ADMIN_CORS_ORIGIN=https://your-admin-domain.example.com

# 必填：学生账号密码入库前的加密密钥；如果启用保存凭据、后台同步或云端同步，生产后不要随意更换。
CREDENTIAL_VAULT_KEY=change-me-to-a-long-random-secret

# 必填：凭据加密密钥版本；首次部署用 v1，只有轮换 CREDENTIAL_VAULT_KEY 时才改。
CREDENTIAL_VAULT_KEY_VERSION=v1


# =========================
# 按功能启用：后端 HTTP 调用云服务
# =========================

# 可选：后端调用云函数 HTTP 地址时附带的内部密钥；云函数校验 x-cschedule-worker-secret 时填写。
CSCHEDULE_WORKER_SECRET=change-me-to-a-secure-random-worker-secret


# =========================
# 按功能启用：后台自动同步
# =========================

# 可选：是否启用后台自动同步；false 时只响应用户手动同步。
AUTO_SYNC_ENABLED=false

# 可选：自动同步扫描间隔，单位毫秒；2H2G 小服务器建议不要低于 600000。
AUTO_SYNC_SCAN_INTERVAL_MS=600000

# 可选：同一账号自动同步最小间隔，单位毫秒；默认 6 小时。
AUTO_SYNC_MIN_INTERVAL_MS=21600000

# 可选：每轮自动同步最多处理的账号数；小服务器建议 10 到 20。
AUTO_SYNC_BATCH_SIZE=20

# 可选：自动同步的数据目标，多个用英文逗号分隔；可选 course、score、exam、profile。
AUTO_SYNC_TARGETS=course


# =========================
# 按功能启用：微信订阅消息提醒
# =========================

# 可选：提醒 worker 初始开关；发送窗口、批量、并发、速率和 dry-run 可在管理后台调整。
REMINDER_ENABLED=false

# 可选：true 表示只试跑不请求微信发送；真实发送必须改为 false，或在管理后台关闭“只试跑，不发送”。
REMINDER_DRY_RUN=true

# 可选：微信小程序 AppID；启用通知提醒真实发送时必须填写。
WECHAT_APP_ID=

# 可选：微信小程序 AppSecret；启用通知提醒真实发送时必须填写，只能放后端。
WECHAT_APP_SECRET=

# 可选：每日课程订阅消息模板 ID；也可以留空后在管理后台填写。
WECHAT_DAILY_COURSE_TEMPLATE_ID=

# 可选：考试订阅消息模板 ID；也可以留空后在管理后台填写。
WECHAT_EXAM_TEMPLATE_ID=

# 可选：微信订阅消息跳转环境；正式版用 formal，体验版用 trial，开发版用 developer。
WECHAT_MINIPROGRAM_STATE=formal

# 可选：订阅消息语言；支持 zh_CN、en_US、zh_HK、zh_TW。
WECHAT_SUBSCRIBE_MESSAGE_LANG=zh_CN


# =========================
# 一般不用改：请求体与同步保护
# =========================

# 可选：普通 JSON 请求体大小限制。
REQUEST_BODY_LIMIT=256kb

# 可选：原始课表、成绩等大 payload 接口的请求体大小限制。
RAW_DATA_BODY_LIMIT=2mb

# 可选：全局同步任务并发数；2H2G 小服务器建议保持 2。
SYNC_GLOBAL_CONCURRENCY=2

# 可选：单个学校同步任务并发数；建议保持 1，避免同一学校接口被并发打爆。
SYNC_SCHOOL_CONCURRENCY=1

# 可选：同步任务超时时间，单位毫秒；超过后会被标记为失败。
SYNC_STALE_JOB_MS=1200000

# 可选：同一账号手动同步冷却时间，单位毫秒；防止用户频繁触发同步。
SYNC_ACCOUNT_COOLDOWN_MS=600000
