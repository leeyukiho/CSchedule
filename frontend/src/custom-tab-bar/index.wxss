.tabbar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 20;
  height: calc(118rpx + env(safe-area-inset-bottom));
  padding-bottom: env(safe-area-inset-bottom);
  display: flex;
  align-items: center;
  border-top: 1rpx solid #e8eaee;
  background: rgba(255, 255, 255, 0.98);
  box-sizing: border-box;
}

.tab {
  flex: 1;
  width: 25%;
  min-width: 0;
  height: 92rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  color: #667085;
  font-size: 21rpx;
  line-height: 1;
}

.tab-active {
  color: #2f7bff;
  font-weight: 700;
}

.tab-icon {
  width: 44rpx;
  height: 44rpx;
  position: relative;
  color: currentColor;
}

.icon-home::before {
  content: "";
  position: absolute;
  left: 8rpx;
  top: 15rpx;
  width: 28rpx;
  height: 22rpx;
  border: 3rpx solid currentColor;
  border-top: 0;
  border-radius: 2rpx;
}

.icon-home::after {
  content: "";
  position: absolute;
  left: 10rpx;
  top: 4rpx;
  width: 24rpx;
  height: 24rpx;
  border-left: 3rpx solid currentColor;
  border-top: 3rpx solid currentColor;
  transform: rotate(45deg);
}

.tab-active .icon-home::before {
  background: currentColor;
}

.icon-calendar {
  border: 3rpx solid currentColor;
  border-radius: 8rpx;
}

.icon-calendar::before {
  content: "";
  position: absolute;
  left: 7rpx;
  right: 7rpx;
  top: 12rpx;
  border-top: 3rpx solid currentColor;
}

.icon-calendar::after {
  content: "";
  position: absolute;
  left: 12rpx;
  top: -7rpx;
  width: 14rpx;
  height: 12rpx;
  border-left: 3rpx solid currentColor;
  border-right: 3rpx solid currentColor;
}

.tab-active .icon-calendar {
  background: currentColor;
}

.tab-active .icon-calendar::before,
.tab-active .icon-calendar::after {
  border-color: #ffffff;
}

.icon-score {
  border: 3rpx solid currentColor;
  border-radius: 8rpx;
}

.icon-score::before {
  content: "";
  position: absolute;
  left: 11rpx;
  bottom: 8rpx;
  width: 4rpx;
  height: 12rpx;
  background: currentColor;
  box-shadow: 8rpx -8rpx 0 currentColor, 16rpx -3rpx 0 currentColor;
}

.tab-active .icon-score {
  background: currentColor;
}

.tab-active .icon-score::before {
  background: #ffffff;
  box-shadow: 8rpx -8rpx 0 #ffffff, 16rpx -3rpx 0 #ffffff;
}

.icon-user::before {
  content: "";
  position: absolute;
  left: 14rpx;
  top: 6rpx;
  width: 16rpx;
  height: 16rpx;
  border: 3rpx solid currentColor;
  border-radius: 50%;
}

.icon-user::after {
  content: "";
  position: absolute;
  left: 8rpx;
  bottom: 3rpx;
  width: 28rpx;
  height: 20rpx;
  border: 3rpx solid currentColor;
  border-radius: 22rpx 22rpx 4rpx 4rpx;
}

.tab-active .icon-user::before,
.tab-active .icon-user::after {
  background: currentColor;
}
