<view class="tabbar">
  <view
    wx:for="{{list}}"
    wx:key="pagePath"
    class="tab {{selected == index ? 'tab-active' : ''}}"
    data-index="{{index}}"
    data-path="{{item.path}}"
    bindtap="switchTab"
    aria-role="button"
    aria-label="{{item.text}}"
  >
    <view class="tab-icon {{item.icon}}"></view>
    <text>{{item.text}}</text>
  </view>
</view>
